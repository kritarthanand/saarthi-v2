# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CHAT_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_CHAT_MODEL_OPUS=claude-opus-4-7

# Supabase — shared project with V1
SUPABASE_URL=https://pedalbyxrzkltfbzbewc.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

PORT=3001

# Dev auth — used by FastAPI endpoints until real JWT auth lands (see TODO: auth)
SAARTHI_DEV_USER_ID=<uuid-from-auth.users>

# Shared secret required to call POST /cron/daily-reset. If unset, the endpoint
# returns 403 — set this even in dev to flip on manual reset triggers.
CRON_SECRET=<random-string>

# Test mode (never in production)
# IS_TEST=true
# SAARTHI_TEST_USER_ID=<uuid>
